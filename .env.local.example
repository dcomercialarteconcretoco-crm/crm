# ============================================================
# CRM Arte Concreto — Variables de Entorno
# Copia este archivo como .env.local y rellena los valores
# ============================================================

# --- WooCommerce API ---
# Obtén estas claves en: WP Admin > WooCommerce > Ajustes > Avanzado > REST API
WOOCOMMERCE_URL=https://tu-tienda.com
WOOCOMMERCE_KEY=ck_xxxxxxxxxxxxxxxxxxxx
WOOCOMMERCE_SECRET=cs_xxxxxxxxxxxxxxxxxxxx

# --- Google Calendar OAuth (cliente Web) ---
# Crea un OAuth Client ID tipo Web application en Google Cloud Console.
# Agrega como Authorized JavaScript Origin tu dominio de Vercel y http://localhost:3000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# --- Resend Email API (para Órdenes de Producción automáticas) ---
# Crea tu cuenta gratis en: https://resend.com
# Obtén tu API Key en: https://resend.com/api-keys
# IMPORTANTE: Debes verificar tu dominio en Resend para poder enviar desde él.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Correo desde el cual se envían las órdenes (debe estar verificado en Resend)
FROM_EMAIL=ordenes@arteconcreto.co

# --- Acceso SuperAdmin (server-side) ---
# Este acceso no vive en el frontend. Se valida desde /api/auth/login.
SUPERADMIN_EMAIL=superadmin@arteconcreto.co
SUPERADMIN_PASSWORD=cambia_esta_clave_por_una_segura

# --- WhatsApp Business Cloud API (Meta) ---
# Crea la app en Meta for Developers y activa WhatsApp.
# Usa estos valores para /api/whatsapp/webhook, /api/whatsapp/health y /api/whatsapp/send
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_BUSINESS_ACCOUNT_ID=1029384756
WHATSAPP_VERIFY_TOKEN=miwibi_verify_token_seguro

# --- Otros (futuro uso) ---
# Agrega aquí nuevas integraciones si luego vuelves a conectar servicios externos.
